# RipTide environment variables
# Copy to .env for local dev, or set these in your host's config (Heroku/Vercel/etc).

# --- Analytics (optional) ---
# Postgres connection string from Neon (https://neon.tech). Without it, analytics
# is silently disabled and the app runs normally.
# Example: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Password for the /stats analytics dashboard login page.
# Used on the /stats/login page to create a session cookie. Without it, /stats is locked.
ADMIN_PASSWORD=

# Optional: secret used to hash anonymous visitor IDs. Set to any random string.
# Defaults to a built-in value if unset (still works, just less unique to you).
ANALYTICS_SALT=

# Secret used to sign admin session cookies. Set to a long random string, e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# If unset, it is derived from ADMIN_PASSWORD + ANALYTICS_SALT (still works, but
# setting it explicitly keeps sessions valid even if you change the password).
SESSION_SECRET=

# --- Cloudflare Turnstile (optional bot protection) ---
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
# Both keys must be set to enable it; otherwise downloads work without a challenge.
# The site key is public (sent to the browser); the secret key must stay private.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
